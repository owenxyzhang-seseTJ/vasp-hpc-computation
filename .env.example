# vasp-hpc-computation configuration template.
# Copy to ~/.config/vasp-hpc-computation/env and fill in your real values.
# This file is sourced by bin/hpc-common. Lines starting with # are comments.
# DO NOT commit a filled-in copy to git (it is gitignored).

# --- SSH relay connection (bin/ helpers) ---
# SSH alias in macOS ~/.ssh/config that reaches the WSL relay.
# export WSL_HOST=wsl-relay

# SSH alias in WSL ~/.ssh/config that reaches the HPC login node.
# export HPC_HOST=hpc-login

# HPC username. REQUIRED.
export HPC_USER=your_hpc_username

# HPC data root directory (override if your cluster uses /share/home/... etc.).
# export HPC_DATA_ROOT=/home/${HPC_USER}/data

# Local JSONL log of submitted jobs.
# export HPC_JOB_LOG=${HOME}/.local/share/vasp-hpc-computation/hpc-jobs.jsonl

# Slurm submit script filename inside each job directory.
# Real projects often use submit.slurm instead of submit.sh.
# export HPC_SUBMIT_SCRIPT=submit.sh

# --- VASP submit-script parameters (export before submitting) ---
# VASP module name on your cluster. Use a VTST-enabled build for NEB.
# export VASP_MODULE=vasp/6.4.2_intel
# export VASP_PARTITION=cpu
