#!/usr/bin/env bash
# hpc-download: Download files from the HPC via WSL relay.
# Usage: hpc-download <remote-path> <local-path>
#   Two-stage transfer: HPC -> WSL relay -> macOS.
#
# Example:
#   hpc-download /home/${HPC_USER}/data/vasp_project/host/OUTCAR ./
#   hpc-download /home/${HPC_USER}/data/vasp_project/host/ ./

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=hpc-common
source "${SCRIPT_DIR}/hpc-common"

if [[ $# -lt 2 ]]; then
    echo "Usage: hpc-download <remote-path-on-hpc> <local-path>"
    echo "Example: hpc-download /home/${HPC_USER}/data/vasp_project/host/OUTCAR ./"
    exit 1
fi

REMOTE_PATH="$1"
LOCAL_PATH="$2"
TMP_DIR="/tmp/hpc-download-$(date +%s)-$$"

echo "Stage 1: HPC -> WSL relay (${HPC_HOST}:${REMOTE_PATH})"
wsl_exec mkdir -p "$TMP_DIR"
ssh "$WSL_HOST" "scp -r $(shell_quote "${HPC_HOST}:${REMOTE_PATH}") $(shell_quote "${TMP_DIR}/")"

echo "Stage 2: WSL relay -> macOS"
scp -r "${WSL_HOST}:${TMP_DIR}/" "${LOCAL_PATH}"
wsl_exec rm -rf "$TMP_DIR"

echo "Download complete."
