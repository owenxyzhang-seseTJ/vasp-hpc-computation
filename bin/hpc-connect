#!/usr/bin/env bash
# hpc-connect: SSH to the HPC directly.
# Usage:
#   hpc-connect
#   hpc-connect --check
#   hpc-connect <command...>

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=hpc-common
source "${SCRIPT_DIR}/hpc-common"

if [[ "${1:-}" == "--check" ]]; then
    check_hpc
    exit 0
fi

if [[ $# -eq 0 ]]; then
    echo "Connecting to ${HPC_HOST}..."
    ssh -t "${HPC_HOST}"
else
    echo "Running on ${HPC_HOST}: $*"
    hpc_exec "$@"
fi
