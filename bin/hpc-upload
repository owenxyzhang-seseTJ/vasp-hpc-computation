#!/usr/bin/env bash
# hpc-upload: Upload local files/directories to the HPC over a direct SSH connection.
# Usage: hpc-upload <local-path> <remote-path>
#
# Example:
#   hpc-upload ./INCAR /home/${HPC_USER}/data/vasp_project/host/
#   hpc-upload ./project_dir /home/${HPC_USER}/data/vasp_project/

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=hpc-common
source "${SCRIPT_DIR}/hpc-common"

if [[ $# -lt 2 ]]; then
    echo "Usage: hpc-upload <local-path> <remote-path-on-hpc>"
    echo "Example: hpc-upload ./INCAR /home/${HPC_USER}/data/vasp_project/host/"
    exit 1
fi

LOCAL_PATH="$1"
REMOTE_PATH="$2"
if [[ ! -e "$LOCAL_PATH" ]]; then
    echo "Local path does not exist: $LOCAL_PATH" >&2
    exit 1
fi

echo "Uploading to ${HPC_HOST}:${REMOTE_PATH}"
hpc_exec mkdir -p "$REMOTE_PATH"
scp -r "${LOCAL_PATH}" "${HPC_HOST}:${REMOTE_PATH}/"

echo "Upload complete."
