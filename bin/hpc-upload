#!/usr/bin/env bash
# hpc-upload: Upload local files/directories to the HPC via WSL relay.
# Usage: hpc-upload <local-path> <remote-path>
#   Two-stage transfer: macOS -> WSL relay -> HPC.
#
# Example:
#   hpc-upload ./INCAR /home/${HPC_USER}/data/vasp_project/host/
#   hpc-upload ./project_dir /home/${HPC_USER}/data/vasp_project/

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=hpc-common
source "${SCRIPT_DIR}/hpc-common"

if [[ $# -lt 2 ]]; then
    echo "Usage: hpc-upload <local-path> <remote-path-on-hpc>"
    echo "Example: hpc-upload ./INCAR /home/${HPC_USER}/data/vasp_project/host/"
    exit 1
fi

LOCAL_PATH="$1"
REMOTE_PATH="$2"
if [[ ! -e "$LOCAL_PATH" ]]; then
    echo "Local path does not exist: $LOCAL_PATH" >&2
    exit 1
fi

BASENAME="$(basename "$LOCAL_PATH")"
TMP_DIR="/tmp/hpc-upload-$(date +%s)-$$"

echo "Stage 1: macOS -> WSL relay (${WSL_HOST})"
wsl_exec mkdir -p "$TMP_DIR"
scp -r "${LOCAL_PATH}" "${WSL_HOST}:${TMP_DIR}/"

echo "Stage 2: WSL relay -> HPC (${HPC_HOST}:${REMOTE_PATH})"
hpc_exec mkdir -p "$REMOTE_PATH"
ssh "$WSL_HOST" "scp -r $(shell_quote "${TMP_DIR}/${BASENAME}") $(shell_quote "${HPC_HOST}:${REMOTE_PATH}/")"
wsl_exec rm -rf "$TMP_DIR"

echo "Upload complete."
